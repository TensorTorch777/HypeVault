# Backend
DATABASE_URL=postgresql+asyncpg://hypevault:hypevault@localhost:5432/hypevault
REDIS_URL=redis://localhost:6379
JWT_SECRET=your-secret-here
JWT_ALGORITHM=HS256
GOOGLE_CLIENT_ID=226562776977-d1lt64ga8r8r1thq3nst89pm56orjk8u.apps.googleusercontent.com
ACCESS_COOKIE_NAME=hv_access
REFRESH_COOKIE_NAME=hv_refresh
# For HTTPS production: COOKIE_SECURE=true and COOKIE_SAMESITE=none
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
AUTH_ACCESS_TOKEN_EXPIRE_HOURS=24
AUTH_REFRESH_TOKEN_EXPIRE_DAYS=7

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET=hypevault-listings
SQS_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/.../HypeVault-Scraping-Queue

# Inference: triton (default) | torch — use torch + LOCAL_MODEL_PATH until RunPod/Triton is up
INFERENCE_BACKEND=triton
# Example after you copy your trained file: INFERENCE_BACKEND=torch
# LOCAL_MODEL_PATH=models/hypevault_classifier.pt
LOCAL_MODEL_PATH=
DINOV2_MODEL_NAME=dinov2_vitg14_reg
# TORCH_DEVICE=cuda

# Triton — inside Docker: TRITON_HOST=triton, TRITON_PORT=8001
# On host (docker-compose gRPC mapped): TRITON_HOST=localhost, TRITON_PORT=18001
TRITON_HOST=localhost
TRITON_PORT=18001
TRITON_MODEL_NAME=dinov2_classifier
TRITON_INPUT_NAME=input__0
TRITON_OUTPUT_NAME=output__0

# Chrono24 region for market-price search (Playwright). India: https://www.chrono24.in
CHRONO24_SEARCH_BASE=https://www.chrono24.in

# ── Inference thresholds (calibrate after validate_real_world.py) ───────────
# sigmoid >= this → FAKE. Default 0.5. Raise to 0.65 if real items are wrongly blocked.
INFERENCE_FAKE_THRESHOLD=0.50
# Predictions between these two values go to human review (treated as FAKE but flagged)
INFERENCE_REVIEW_LOW=0.40
INFERENCE_REVIEW_HIGH=0.60
INFERENCE_LIVE_CONF_THRESHOLD=0.90
REPORT_ENFORCE_TRITON=true
UPLOAD_MIN_SIDE_PX=400
UPLOAD_MAX_BYTES=10485760

# Frontend (must match the port you run `next dev` on)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Optional: extra CORS origins (comma-separated). Always merged with localhost :3000 / :3001.
# CORS_ORIGINS=https://your-preview.example.com